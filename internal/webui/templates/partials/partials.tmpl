{{define "mrnav"}}
<nav class="mrnav">
  <a href="{{.Nav.DetailURL}}">overview</a>
  <a href="{{.Nav.DiffURL}}">diff</a>
  <a href="{{.Nav.HistoryURL}}">past reviews</a>
  {{if .WebURL}}<a href="{{.WebURL}}" target="_blank" rel="noopener">open in GitLab {{template "icon" "external"}}</a>{{end}}
</nav>
{{end}}

{{/* mrhead is the MR metadata line; dot is the *gitlabx.MRDetail. Each part
     links to its GitLab page when the URL is derivable from the MR's WebURL. */}}
{{define "mrhead"}}
{{$src := .BranchWebURL .SourceBranch}}{{$tgt := .BranchWebURL .TargetBranch}}
<p class="subtle mrhead">
  {{if .WebURL}}<a href="{{.WebURL}}" target="_blank" rel="noopener">{{.Ref}}</a>{{else}}{{.Ref}}{{end}}
  · {{if .AuthorWebURL}}<a href="{{.AuthorWebURL}}" target="_blank" rel="noopener">{{.AuthorDisplay}}</a>{{else}}{{.AuthorDisplay}}{{end}}
  · {{if $src}}<a href="{{$src}}" target="_blank" rel="noopener">{{.SourceBranch}}</a>{{else}}{{.SourceBranch}}{{end}}
  → {{if $tgt}}<a href="{{$tgt}}" target="_blank" rel="noopener">{{.TargetBranch}}</a>{{else}}{{.TargetBranch}}{{end}}
  · updated {{reltime .UpdatedAt}} · {{.State}}
</p>
{{end}}

{{define "sevbadge"}}{{if .Manual}}<span class="badge manual">manual</span>{{else}}<span class="badge sev-{{.Severity}}">{{.Severity}}{{if .Category}} · {{.Category}}{{end}}{{if and .Agent (ne .Agent (printf "%s" .Category))}} · {{.Agent}}{{end}}</span>{{end}}{{end}}

{{define "statebadge"}}<span class="badge fstate state-{{fstate .}}">{{fstate .}}</span>{{end}}

{{/* findingactions are the accept/reject forms for one finding; dot carries
     F, Nav, StateURL, RecordName and an optional BackURL to return to. The
     forms work without JS; app.js upgrades them to in-place updates. */}}
{{define "findingactions"}}
<form method="post" action="{{.StateURL}}" class="inline-form f-state-form">
  <input type="hidden" name="project" value="{{.Nav.Project}}">
  <input type="hidden" name="iid" value="{{.Nav.IID}}">
  <input type="hidden" name="record" value="{{.RecordName}}">
  <input type="hidden" name="id" value="{{.F.ID}}">
  <input type="hidden" name="back" value="{{.BackURL}}">
  <input type="hidden" name="action" value="accept">
  <button type="submit" class="button ok">{{template "icon" "check"}} Accept</button>
</form>
<form method="post" action="{{.StateURL}}" class="inline-form f-state-form">
  <input type="hidden" name="project" value="{{.Nav.Project}}">
  <input type="hidden" name="iid" value="{{.Nav.IID}}">
  <input type="hidden" name="record" value="{{.RecordName}}">
  <input type="hidden" name="id" value="{{.F.ID}}">
  <input type="hidden" name="back" value="{{.BackURL}}">
  <input type="hidden" name="action" value="reject">
  <button type="submit" class="button danger">{{template "icon" "cross"}} Reject</button>
</form>
{{end}}

{{define "excerpt"}}
{{if .}}
<table class="diff excerpt">
{{range .}}
  {{if eq .Kind "hunk"}}
  <tr class="hunk"><td class="ln"></td><td class="ln"></td><td class="code">{{.HTML}}</td></tr>
  {{else}}
  <tr class="line {{.Kind}}">
    <td class="ln">{{if .Old}}{{.Old}}{{end}}</td>
    <td class="ln">{{if .New}}{{.New}}{{end}}</td>
    <td class="code">{{.HTML}}</td>
  </tr>
  {{end}}
{{end}}
</table>
{{end}}
{{end}}

{{/* diffcontext renders the unchanged lines revealed by expanding a hunk's
     context: unified or split rows the diff page splices around the hunk. */}}
{{define "diffcontext"}}{{if .Split}}{{range .Rows}}{{template "ctxrow-split" .}}{{end}}{{else}}{{range .Rows}}{{template "ctxrow-unified" .}}{{end}}{{end}}{{end}}

{{define "ctxrow-unified"}}<tr class="line ctx" data-file="{{.File}}" data-old="{{.Old}}" data-new="{{.New}}"><td class="ln">{{.Old}}</td><td class="ln">{{.New}}</td><td class="gutter"><button type="button" class="add-comment" title="add a comment on this line">+</button></td><td class="code">{{.HTML}}</td></tr>{{end}}

{{define "ctxrow-split"}}<tr class="line"><td class="ln ctx">{{.Old}}</td><td class="gutter ctx"></td><td class="code ctx">{{.HTML}}</td><td class="ln ctx">{{.New}}</td><td class="gutter ctx"><button type="button" class="add-comment" title="add a comment on this line" data-file="{{.File}}" data-old="{{.Old}}" data-new="{{.New}}">+</button></td><td class="code ctx">{{.HTML}}</td></tr>{{end}}
