{{define "content"}}
{{$c := .Content}}
{{template "mrnav" (navargs $c.Nav $c.Detail.WebURL)}}
<section class="panel">
  <h2>{{if $c.Detail.Draft}}<span class="badge draft">draft</span> {{end}}{{$c.Detail.Title}}</h2>
  {{template "mrhead" $c.Detail}}

  {{if $c.RebaseWarning}}<p class="warning">⚠ {{$c.RebaseWarning}}</p>{{end}}
  {{with $c.Approvals}}
    {{if .ApprovedBy}}<p class="ok">✓ Approved by {{join .ApprovedBy ", "}}</p>
    {{else if .ApprovalsRequired}}<p class="subtle">{{.ApprovalsLeft}} of {{.ApprovalsRequired}} required approval(s) outstanding</p>{{end}}
  {{end}}

  <div class="actions">
    <a class="button primary" href="{{$c.Nav.DiffURL}}">View diff</a>
    <form method="post" action="{{$c.Nav.ReviewURL}}" class="review-form">
      <input type="hidden" name="project" value="{{$c.Nav.Project}}">
      <input type="hidden" name="iid" value="{{$c.Nav.IID}}">
      <button type="submit" class="button review">▶ Run AI review</button>
      <details class="agent-select">
        <summary>agents</summary>
        <fieldset>
          {{range $c.AgentOptions}}
          <label title="{{.Description}}">
            <input type="checkbox" name="agents" value="{{.Name}}"{{if .Checked}} checked{{end}}>
            {{.Name}}{{if .Source}} <span class="badge">{{.Source}}</span>{{end}}
            <select name="model:{{.Name}}" class="agent-model" title="model for {{.Name}}">
              {{range .Models}}<option value="{{.Value}}"{{if .Selected}} selected{{end}}>{{.Label}}</option>{{end}}
            </select>
          </label>
          {{end}}
        </fieldset>
        {{range $c.AgentWarnings}}<p class="warning">⚠ {{.}}</p>{{end}}
      </details>
    </form>
    <form method="post" action="{{$c.Nav.ChatURL}}">
      <input type="hidden" name="project" value="{{$c.Nav.Project}}">
      <input type="hidden" name="iid" value="{{$c.Nav.IID}}">
      <button type="submit" class="button">💬 Chat with Claude</button>
    </form>
    <a class="button" href="{{$c.Nav.HistoryURL}}">Past reviews</a>
    {{if $c.HasAccepted}}<a class="button" href="{{$c.Nav.PublishURL}}">Publish comments</a>{{end}}
    {{if and $c.Approvals $c.Approvals.UserCanApprove}}
    <form method="post" action="{{$c.Nav.ApproveURL}}">
      <input type="hidden" name="project" value="{{$c.Nav.Project}}">
      <input type="hidden" name="iid" value="{{$c.Nav.IID}}">
      <input type="hidden" name="back" value="{{$c.Nav.DetailURL}}">
      {{if $c.Approvals.UserHasApproved}}
      <input type="hidden" name="action" value="unapprove">
      <button type="submit" class="button">Unapprove</button>
      {{else}}
      <input type="hidden" name="sha" value="{{$c.Detail.HeadSHA}}">
      <button type="submit" class="button ok">✓ Approve</button>
      {{end}}
    </form>
    {{end}}
  </div>

  {{if $c.Detail.Description}}
  <h3>Description</h3>
  <div class="md">{{markdown $c.Detail.Description}}</div>
  {{end}}

  {{if $c.Commits}}
  <h3>Commits</h3>
  <ul class="commits">
    {{range $c.Commits}}
    <li><code>{{.ShortID}}</code> {{.Title}}</li>
    {{end}}
  </ul>
  {{end}}

  <h3>Your pending comments</h3>
  {{if $c.Pending}}
  <ul class="pending-comments">
    {{range $c.Pending}}
    <li id="c-{{.ID}}">
      <span class="badge manual">{{fstate .State}}</span>
      <span class="subtle">{{floc .}}</span>
      <span class="body">{{ftitle .}}</span>
      {{if eq (fstate .State) "accepted"}}
      <form method="post" action="{{$c.Nav.DeleteURL}}" class="inline-form">
        <input type="hidden" name="project" value="{{$c.Nav.Project}}">
        <input type="hidden" name="iid" value="{{$c.Nav.IID}}">
        <input type="hidden" name="id" value="{{.ID}}">
        <input type="hidden" name="back" value="{{$c.Nav.DetailURL}}">
        <button type="submit" class="link danger">delete</button>
      </form>
      {{end}}
    </li>
    {{end}}
  </ul>
  {{else}}
  <p class="note">None yet — add them below or from the diff view. They publish together with accepted review findings, or on their own.</p>
  {{end}}

  <details class="new-comment">
    <summary>Add an MR-level comment</summary>
    <form method="post" action="{{$c.Nav.CommentURL}}">
      <input type="hidden" name="project" value="{{$c.Nav.Project}}">
      <input type="hidden" name="iid" value="{{$c.Nav.IID}}">
      <input type="hidden" name="back" value="{{$c.Nav.DetailURL}}">
      <textarea name="body" rows="4" placeholder="posted verbatim as your own comment — markdown supported"></textarea>
      <button type="submit" class="button">Add comment</button>
    </form>
  </details>
</section>
{{end}}
