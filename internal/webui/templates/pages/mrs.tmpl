{{define "content"}}
{{$c := .Content}}
<section class="panel">
  <form method="get" class="filters">
    <select name="state">
      <option value="opened" {{if or (eq $c.State "opened") (eq $c.State "")}}selected{{end}}>opened</option>
      <option value="merged" {{if eq $c.State "merged"}}selected{{end}}>merged</option>
      <option value="closed" {{if eq $c.State "closed"}}selected{{end}}>closed</option>
      <option value="all" {{if eq $c.State "all"}}selected{{end}}>all</option>
    </select>
    <input type="search" name="search" placeholder="search title/description" value="{{$c.Search}}">
    <input type="text" name="author" placeholder="author username" value="{{$c.Author}}">
    <input type="text" name="target" placeholder="target branch" value="{{$c.Target}}">
    {{if $c.NeedsScope}}
    <input type="text" name="projects" placeholder="projects (group/app, comma-separated)" value="{{$c.Projects}}">
    <input type="text" name="groups" placeholder="groups (comma-separated)" value="{{$c.Groups}}">
    {{else}}
    <input type="hidden" name="projects" value="{{$c.Projects}}">
    <input type="hidden" name="groups" value="{{$c.Groups}}">
    {{end}}
    <button type="submit">Filter</button>
    {{if $c.NeedsScope}}<a class="button" href="{{$c.BrowseURL}}">Browse groups &amp; projects</a>{{end}}
  </form>

  {{if $c.Err}}<p class="error">{{$c.Err}}</p>{{end}}

  {{if $c.MRs}}
  <div class="table-scroll">
  <table class="list">
    <thead><tr><th>!IID</th><th>Title</th><th>Project</th><th>Author</th><th>Target</th><th>Status</th><th>Review</th><th>Updated</th></tr></thead>
    <tbody>
      {{range $i, $m := $c.MRs}}
      <tr>
        <td>!{{$m.IID}}</td>
        <td class="mr-title"><a href="{{call $c.MRURL $m}}">{{if $m.Draft}}<span class="badge draft">draft</span> {{end}}{{$m.Title}}</a></td>
        <td class="subtle">{{$m.ProjectPath}}</td>
        <td class="subtle mr-author">{{$m.AuthorDisplay}}</td>
        <td class="subtle">{{$m.TargetBranch}}</td>
        <td class="mr-status" data-status-url="{{call $c.StatusURL $m}}"></td>
        <td>{{with index $c.Reviewed $i}}<a class="badge reviewed" href="{{.URL}}" title="last reviewed {{reltime .When}} — {{.Findings}} finding(s), {{.Accepted}} accepted">{{template "icon" "check"}} reviewed{{if .Findings}} · {{.Findings}}{{end}}</a>{{end}}</td>
        <td class="subtle mr-updated">{{reltime $m.UpdatedAt}}</td>
      </tr>
      {{end}}
    </tbody>
  </table>
  </div>
  {{else if not $c.NeedsScope}}
  <p class="note">No merge requests match.</p>
  {{end}}

  <div class="pager">
    {{if $c.PrevURL}}<a class="button" href="{{$c.PrevURL}}">← newer</a>{{end}}
    {{if $c.NextURL}}<a class="button" href="{{$c.NextURL}}">older →</a>{{end}}
  </div>
</section>
{{end}}
