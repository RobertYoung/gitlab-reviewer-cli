{{define "content"}}
{{$c := .Content}}
{{template "mrnav" (navargs $c.Nav $c.Detail.WebURL)}}
<header class="mr-header">
  {{template "mrhead" $c.Detail}}
  {{if $c.Detail.Description}}
  <details class="mr-description panel">
    <summary>{{if $c.Detail.Draft}}<span class="badge draft">draft</span> {{end}}{{$c.Detail.Title}}</summary>
    <div class="md">{{markdown $c.Detail.Description}}</div>
  </details>
  {{end}}
</header>
<div class="diff-layout" data-viewed-key="viewed:{{$c.Nav.Project}}!{{$c.Nav.IID}}@{{$c.Detail.HeadSHA}}" data-ctx-url="{{$c.ContextURL}}" data-ctx-ref="{{$c.HeadSHA}}">
  <aside class="filetree">
    <h3>{{len $c.Files}} changed file{{if ne (len $c.Files) 1}}s{{end}} <span class="viewed-progress" id="viewed-progress"></span></h3>
    <ul>
      {{range $c.Explorer}}{{template "explorernode" .}}{{end}}
    </ul>
    <p class="view-toggle subtle">layout:
      {{if $c.Split}}<a href="{{$c.UnifiedURL}}">unified</a> · <strong>split</strong>
      {{else}}<strong>unified</strong> · <a href="{{$c.SplitURL}}">split</a>{{end}}
    </p>
    <div class="actions column">
      {{template "reviewform" (reviewformargs $c.Nav $c.AgentOptions $c.AgentWarnings $c.PrevReviewHead)}}
      <form method="post" action="{{$c.Nav.ChatURL}}">
        <input type="hidden" name="project" value="{{$c.Nav.Project}}">
        <input type="hidden" name="iid" value="{{$c.Nav.IID}}">
        <button type="submit" class="button">{{template "icon" "chat"}} Chat about this MR</button>
      </form>
      {{if $c.HasAccepted}}<a class="button" href="{{$c.Nav.PublishURL}}">Publish comments</a>{{end}}
    </div>
  </aside>

  <section class="diff-files">
    {{if $c.RecordName}}
    <p class="findings-banner subtle">
      Findings from the review of {{reltime $c.RecordTime}} are shown inline.
      <a href="{{$c.FindingsURL}}">Open the findings page</a> to edit or publish them.
    </p>
    {{end}}

    {{if $c.GeneralFindings}}
    <div class="panel">
      <h3>MR-level findings</h3>
      {{range $c.GeneralFindings}}
      {{template "difffinding" (findingrow . $c)}}
      {{end}}
    </div>
    {{end}}

    {{if $c.General}}
    <div class="panel">
      <h3>Pending MR-level comments</h3>
      <ul class="pending-comments">
        {{range $c.General}}
        <li><span class="badge manual">{{fstate .State}}</span> {{ftitle .}}</li>
        {{end}}
      </ul>
    </div>
    {{end}}

    {{range $c.Files}}
    <article class="diff-file" id="file-{{.Index}}" data-path="{{.NewPath}}">
      <header class="file-header">
        <button type="button" class="file-fold" title="collapse / expand this file" aria-label="collapse or expand"></button>
        <span class="fstatus fstatus-{{.Status}}">{{.Letter}}</span> <span class="fpath">{{.Path}}</span>
        {{if .Comments}}<span class="badge comments">{{template "icon" "chat"}} {{.Comments}}</span>{{end}}
        {{if .Findings}}<span class="badge findingcount">{{template "icon" "warn"}} {{.Findings}}</span>{{end}}
        <span class="spacer"></span>
        <label class="viewed-label subtle"><input type="checkbox" class="viewed-box"> viewed</label>
      </header>
      <div class="file-body">
      {{if .TooLarge}}<p class="note">This file's diff is too large to display.</p>{{end}}
      {{$file := .}}
      {{if $c.Split}}
      <table class="diff split">
        {{/* fixed layout sizes columns from the first row, which is usually a
             colspan'd hunk header — pin the widths with cols instead */}}
        <colgroup>
          <col class="c-ln"><col class="c-gutter"><col class="c-code">
          <col class="c-ln"><col class="c-gutter"><col class="c-code">
        </colgroup>
        {{range .Rows}}
        {{if .Hunk}}
        <tr class="hunk"{{with .Expand}} data-ctx-new="{{.New}}" data-ctx-offset="{{.Offset}}" data-ctx-min="{{.Min}}"{{end}}><td class="ln" colspan="2">{{if .Expand}}<button type="button" class="expand-ctx" title="show more lines above">↕</button>{{end}}</td><td class="code" colspan="4">{{.Hunk}}</td></tr>
        {{else}}
        <tr class="line">
          <td class="ln {{.Left.Kind}}">{{if .Left.Num}}{{.Left.Num}}{{end}}</td>
          <td class="gutter {{.Left.Kind}}">{{if eq .Left.Kind "del"}}<button type="button" class="add-comment" title="add a comment on this line" data-file="{{$file.NewPath}}" data-old="{{.Left.Num}}" data-new="">+</button>{{end}}</td>
          <td class="code {{.Left.Kind}}">{{.Left.HTML}}</td>
          <td class="ln {{.Right.Kind}}">{{if .Right.Num}}{{.Right.Num}}{{end}}</td>
          <td class="gutter {{.Right.Kind}}">{{if eq .Right.Kind "add"}}<button type="button" class="add-comment" title="add a comment on this line" data-file="{{$file.NewPath}}" data-old="" data-new="{{.Right.Num}}">+</button>{{else if eq .Right.Kind "ctx"}}<button type="button" class="add-comment" title="add a comment on this line" data-file="{{$file.NewPath}}" data-old="{{.Left.Num}}" data-new="{{.Right.Num}}">+</button>{{end}}</td>
          <td class="code {{.Right.Kind}}">{{.Right.HTML}}</td>
        </tr>
        {{range .Findings}}
        <tr class="inline-comment"><td colspan="2" class="ln"></td><td colspan="4">{{template "difffinding" (findingrow . $c)}}</td></tr>
        {{end}}
        {{range .Threads}}
        <tr class="inline-comment"><td colspan="2" class="ln"></td><td colspan="4">{{template "diffthread" (threadrow . $c)}}</td></tr>
        {{end}}
        {{end}}
        {{end}}
        {{with $file.Tail}}
        <tr class="hunk expander-tail" data-ctx-new="{{.New}}" data-ctx-offset="{{.Offset}}" data-ctx-down="1"><td class="ln" colspan="2"><button type="button" class="expand-ctx" title="show more lines below">↓</button></td><td class="code" colspan="4"></td></tr>
        {{end}}
      </table>
      {{else}}
      <table class="diff">
        {{range .Lines}}
        {{if eq .Kind "hunk"}}
        <tr class="hunk"{{with .Expand}} data-ctx-new="{{.New}}" data-ctx-offset="{{.Offset}}" data-ctx-min="{{.Min}}"{{end}}><td class="ln" colspan="3">{{if .Expand}}<button type="button" class="expand-ctx" title="show more lines above">↕</button>{{end}}</td><td class="code">{{.HTML}}</td></tr>
        {{else}}
        <tr class="line {{.Kind}}" data-file="{{$file.NewPath}}" data-old="{{.Old}}" data-new="{{.New}}">
          <td class="ln">{{if .Old}}{{.Old}}{{end}}</td>
          <td class="ln">{{if .New}}{{.New}}{{end}}</td>
          <td class="gutter">{{if .CanComment}}<button type="button" class="add-comment" title="add a comment on this line">+</button>{{end}}</td>
          <td class="code">{{.HTML}}</td>
        </tr>
        {{range .Findings}}
        <tr class="inline-comment"><td colspan="3" class="ln"></td><td>{{template "difffinding" (findingrow . $c)}}</td></tr>
        {{end}}
        {{range .Threads}}
        <tr class="inline-comment"><td colspan="3" class="ln"></td><td>{{template "diffthread" (threadrow . $c)}}</td></tr>
        {{end}}
        {{end}}
        {{end}}
        {{with $file.Tail}}
        <tr class="hunk expander-tail" data-ctx-new="{{.New}}" data-ctx-offset="{{.Offset}}" data-ctx-down="1"><td class="ln" colspan="3"><button type="button" class="expand-ctx" title="show more lines below">↓</button></td><td class="code"></td></tr>
        {{end}}
      </table>
      {{end}}
      </div>
    </article>
    {{end}}
  </section>
</div>

<template id="comment-form-template">
  <tr class="inline-comment new"><td class="ln"></td><td>
    <form method="post" action="{{$c.Nav.CommentURL}}" class="comment-form">
      <input type="hidden" name="project" value="{{$c.Nav.Project}}">
      <input type="hidden" name="iid" value="{{$c.Nav.IID}}">
      <input type="hidden" name="back" value="{{$c.BackURL}}">
      <input type="hidden" name="file" value="">
      <input type="hidden" name="old" value="">
      <input type="hidden" name="new" value="">
      <textarea name="body" rows="3" placeholder="posted verbatim as your own comment — markdown supported"></textarea>
      <div class="actions">
        <button type="submit" class="button primary">Add comment</button>
        <button type="submit" class="button" formaction="{{$c.Nav.ChatURL}}" title="open a chat with Claude about this line — your text becomes the first message">{{template "icon" "chat"}} Ask Claude</button>
        <button type="button" class="button cancel-comment">Cancel</button>
      </div>
    </form>
  </td></tr>
</template>
{{end}}

{{define "explorernode"}}
{{if .File}}
<li class="file-entry" data-path="{{.File.NewPath}}"><a href="#file-{{.File.Index}}" title="{{.File.Path}}"><span class="fstatus fstatus-{{.File.Status}}">{{.File.Letter}}</span><span class="fname">{{.Name}}</span>{{if .File.Comments}}<span class="badge comments">{{template "icon" "chat"}} {{.File.Comments}}</span>{{end}}{{if .File.Findings}}<span class="badge findingcount">{{template "icon" "warn"}} {{.File.Findings}}</span>{{end}}<span class="viewed-tick">{{template "icon" "check"}}</span></a></li>
{{else}}
<li>
  <details open>
    <summary title="fold/unfold">{{.Name}}/</summary>
    <ul>
      {{range .Children}}{{template "explorernode" .}}{{end}}
    </ul>
  </details>
</li>
{{end}}
{{end}}

{{define "difffinding"}}
<div class="finding f-inline state-{{fstate .F.State}}" data-finding="{{.F.ID}}">
  <header>
    {{template "sevbadge" .F}}
    <strong class="ftitle">{{ftitle .F}}</strong>
    <span class="spacer"></span>
    {{template "statebadge" .F.State}}
  </header>
  <pre class="prose">{{.F.Body}}</pre>
  {{if .F.Suggestion}}
  <div class="suggestion">
    <span class="subtle">suggested replacement:</span>
    <pre class="prose add">+{{.F.Suggestion}}</pre>
  </div>
  {{end}}
  <footer class="actions">
    {{template "findingactions" .}}
    {{if .FindingsURL}}<a class="subtle" href="{{.FindingsURL}}#f-{{.F.ID}}">open in findings</a>{{end}}
  </footer>
</div>
{{end}}

{{define "diffthread"}}
{{$content := .Content}}
<details class="thread{{if .T.Resolved}} resolved{{end}}"{{if not .T.Resolved}} open{{end}}>
  <summary>
    <span class="who">{{template "icon" "chat"}} {{with .T.First}}{{if .Pending}}yours{{else}}{{.Author}}{{end}}{{end}}</span>
    {{if gt (len .T.Comments) 1}}<span class="subtle">· {{len .T.Comments}} comments</span>{{end}}
    {{with .T.First}}{{if not .When.IsZero}}<span class="subtle">· {{reltime .When}}</span>{{end}}{{end}}
    {{if .T.Resolved}}<span class="badge resolved">resolved</span>{{end}}
  </summary>
  {{range .T.Comments}}{{template "diffcomment" (commentrow . $content)}}{{end}}
</details>
{{end}}

{{define "diffcomment"}}
<div class="comment{{if .C.Pending}} pending{{end}}">
  <div class="meta">
    {{if .C.Pending}}<span class="badge manual">yours · {{.C.State}}</span>{{else}}<strong>{{.C.Author}}</strong> <span class="subtle">{{reltime .C.When}}</span>{{end}}
  </div>
  <pre class="prose">{{.C.Body}}</pre>
  {{if and .C.Pending .C.ID}}
  <form method="post" action="{{.Nav.DeleteURL}}" class="inline-form">
    <input type="hidden" name="project" value="{{.Nav.Project}}">
    <input type="hidden" name="iid" value="{{.Nav.IID}}">
    <input type="hidden" name="id" value="{{.C.ID}}">
    <input type="hidden" name="back" value="{{.BackURL}}">
    <button type="submit" class="link danger">delete</button>
  </form>
  {{end}}
</div>
{{end}}
