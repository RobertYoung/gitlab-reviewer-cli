{{define "content"}}
{{$c := .Content}}
<section class="panel narrow-wide">
  <h2>Settings</h2>
  <p class="subtle">Editing <code>{{$c.FilePath}}</code>{{if not $c.FileExists}} <span class="note">(not created yet — saving creates it)</span>{{end}}.</p>
  <p class="note">These are the effective values. Environment variables and command-line flags still override the file at runtime. {{if $c.HotReload}}Saved changes apply to subsequent actions without a restart.{{else}}Saved changes apply the next time you start the GUI.{{end}}</p>
  {{if $c.Saved}}
  {{if $c.Applied}}<p class="ok">{{template "icon" "check"}} Saved to {{$c.FilePath}} and applied.</p>
  {{else if $c.HotReload}}<p class="warning">{{template "icon" "warn"}} Saved to {{$c.FilePath}}, but the running session kept the previous settings — restart the GUI to apply.</p>
  {{else}}<p class="ok">{{template "icon" "check"}} Saved to {{$c.FilePath}}. Restart the GUI to apply.</p>{{end}}
  {{end}}
  {{if $c.Err}}<div class="warning">{{template "icon" "warn"}} Could not save:</div><pre class="error">{{$c.Err}}</pre>{{end}}
</section>

<form method="post" action="{{$c.SaveURL}}" class="settings-form" autocomplete="off">
  {{range $c.Sections}}
  <section class="panel settings-section" id="sec-{{.Anchor}}">
    <h3>{{.Title}}</h3>
    {{if .Help}}<p class="subtle">{{.Help}}</p>{{end}}
    {{range .Views}}
    {{template "settingfield" .}}
    {{end}}
  </section>
  {{end}}

  <section class="panel settings-section" id="sec-instances">
    <h3>GitLab instances</h3>
    <p class="subtle">Named GitLab connections to switch between at startup. Leave this empty to use the single connection under GitLab above. To remove an instance, clear its name (or press Remove) and save; a blank token keeps the value already stored.</p>
    <div class="instance-editor" id="instance-editor" data-next-index="{{len $c.Instances}}">
      {{range $c.Instances}}{{template "instancerow" .}}{{end}}
      {{template "instancerow" (blankinstance (len $c.Instances))}}
    </div>
    <button type="button" class="button" id="add-instance">Add instance</button>
  </section>

  <div class="actions settings-actions">
    <button type="submit" class="button primary">Save settings</button>
    <a class="button" href="/">Cancel</a>
  </div>
</form>
{{end}}

{{define "instancerow"}}
<fieldset class="instance-row" data-instance-row>
  <input type="hidden" name="instance.{{.Index}}.orig_name" value="{{.Name}}">
  <div class="setting">
    <label class="setting-label" for="inst-{{.Index}}-name">Name</label>
    <input type="text" id="inst-{{.Index}}-name" name="instance.{{.Index}}.name" value="{{.Name}}" spellcheck="false" placeholder="e.g. work">
  </div>
  <div class="setting">
    <label class="setting-label" for="inst-{{.Index}}-url">Base URL</label>
    <input type="text" id="inst-{{.Index}}-url" name="instance.{{.Index}}.base_url" value="{{.BaseURL}}" spellcheck="false" placeholder="https://gitlab.example.com">
  </div>
  <div class="setting">
    <label class="setting-label" for="inst-{{.Index}}-token">Token</label>
    <input type="password" id="inst-{{.Index}}-token" name="instance.{{.Index}}.token" autocomplete="new-password" placeholder="{{if .TokenSet}}configured — leave blank to keep{{else}}not set — or use a token env var{{end}}">
  </div>
  <div class="setting">
    <label class="setting-label" for="inst-{{.Index}}-tokenenv">Token env var</label>
    <input type="text" id="inst-{{.Index}}-tokenenv" name="instance.{{.Index}}.token_env" value="{{.TokenEnv}}" spellcheck="false" placeholder="e.g. WORK_GITLAB_TOKEN">
    <span class="help">Environment variable read for the token when Token is left blank.</span>
  </div>
  <button type="button" class="button danger" data-remove-instance>Remove</button>
</fieldset>
{{end}}

{{define "settingfield"}}
<div class="setting setting-{{.Kind}}">
  {{if .Is "bool"}}
  <label class="setting-check">
    <input type="checkbox" name="{{.Key}}" {{if .Checked}}checked{{end}}>
    <span class="setting-label">{{.Label}}</span>
  </label>
  {{if .Help}}<span class="help">{{.Help}}</span>{{end}}
  {{else}}
  <label class="setting-label" for="f-{{.Key}}">{{.Label}}</label>
  {{if .Help}}<span class="help">{{.Help}}</span>{{end}}
  {{if .Is "select"}}
  {{$val := .Value}}
  <select id="f-{{.Key}}" name="{{.Key}}">
    {{range .Options}}
    <option value="{{.}}" {{if eq . $val}}selected{{end}}>{{if eq . ""}}(unset — disabled){{else}}{{.}}{{end}}</option>
    {{end}}
  </select>
  {{else if or (.Is "list") (.Is "map")}}
  <textarea id="f-{{.Key}}" name="{{.Key}}" rows="4" spellcheck="false">{{.Text}}</textarea>
  {{else if .Is "secret"}}
  <input type="password" id="f-{{.Key}}" name="{{.Key}}" autocomplete="new-password"
    placeholder="{{if .TokenSet}}configured — leave blank to keep{{else}}not set{{end}}">
  {{else if .Is "int"}}
  <input type="number" step="1" id="f-{{.Key}}" name="{{.Key}}" value="{{.Value}}">
  {{else if .Is "float"}}
  <input type="number" step="any" id="f-{{.Key}}" name="{{.Key}}" value="{{.Value}}">
  {{else}}
  <input type="text" id="f-{{.Key}}" name="{{.Key}}" value="{{.Value}}" spellcheck="false">
  {{end}}
  {{end}}
</div>
{{end}}
