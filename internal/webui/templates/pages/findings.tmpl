{{define "content"}}
{{$c := .Content}}
{{template "mrnav" (navargs $c.Nav $c.Detail.WebURL)}}
<section class="panel findings-page" data-record="{{$c.RecordName}}">
  <h2>Findings · {{$c.Detail.Ref}}</h2>
  {{if $c.AutoPublished}}
  <p class="ok" role="status">{{template "icon" "check"}} Auto-published {{$c.AutoPublished}} qualifying finding(s) to GitLab (<code>publish.auto_comment</code>). No further action needed.</p>
  {{end}}
  {{if $c.Rec.Summary}}<pre class="prose summary">{{$c.Rec.Summary}}</pre>{{end}}
  {{range $c.Rec.Warnings}}<p class="warning">{{template "icon" "warn"}} {{.}}</p>{{end}}

  <div class="actions">
    <a class="button" href="{{$c.DiffURL}}">View in diff</a>
    {{if $c.LogURL}}<a class="button" href="{{$c.LogURL}}">{{template "icon" "log"}} Run log</a>{{end}}
    <span class="spacer"></span>
    <span class="filter-chips" id="finding-filters" hidden>
      <button type="button" class="chip" data-filter-state="pending">pending</button>
      <button type="button" class="chip" data-filter-state="accepted">accepted</button>
      <button type="button" class="chip" data-filter-state="rejected">rejected</button>
      <span class="chip-sep"></span>
      <button type="button" class="chip" data-filter-sev="critical">critical</button>
      <button type="button" class="chip" data-filter-sev="major">major</button>
      <button type="button" class="chip" data-filter-sev="minor">minor</button>
      <button type="button" class="chip" data-filter-sev="info">info</button>
    </span>
  </div>

  {{if not $c.Items}}
  <p class="note">The reviewer found nothing to flag.</p>
  {{end}}

  {{range $c.Items}}
  {{$f := .F}}
  <article class="finding state-{{fstate $f.State}}" id="f-{{$f.ID}}" data-finding="{{$f.ID}}" data-severity="{{$f.Severity}}" tabindex="-1">
    <header>
      {{template "sevbadge" $f}}
      <strong class="ftitle">{{ftitle $f}}</strong>
      <span class="subtle">{{floc $f}}</span>
      <span class="spacer"></span>
      {{template "statebadge" $f.State}}
    </header>
    <pre class="prose">{{$f.Body}}</pre>
    {{if $f.Suggestion}}
    <div class="suggestion">
      <span class="subtle">suggested replacement:</span>
      <pre class="prose add">+{{$f.Suggestion}}</pre>
    </div>
    {{end}}
    {{template "excerpt" .Excerpt}}
    <footer class="actions">
      {{template "findingactions" (triagerow $f $c)}}
      <details class="edit">
        <summary class="button">Edit body</summary>
        <form method="post" action="{{$c.StateURL}}" class="f-edit-form">
          <input type="hidden" name="project" value="{{$c.Nav.Project}}">
          <input type="hidden" name="iid" value="{{$c.Nav.IID}}">
          <input type="hidden" name="record" value="{{$c.RecordName}}">
          <input type="hidden" name="id" value="{{$f.ID}}">
          <input type="hidden" name="action" value="edit">
          <textarea name="body" rows="6">{{$f.Body}}</textarea>
          <button type="submit" class="button primary">Save</button>
        </form>
      </details>
    </footer>
  </article>
  {{end}}
</section>

{{if $c.Items}}
<footer class="triage-bar" id="triage-bar">
  <span class="counts">
    <span class="count ok"><b id="count-accepted">{{$c.Accepted}}</b> accepted</span>
    <span class="count danger"><b id="count-rejected">{{$c.Rejected}}</b> rejected</span>
    <span class="count"><b id="count-pending">{{$c.Pending}}</b> pending</span>
    {{if $c.Published}}<span class="count ok"><b id="count-published">{{$c.Published}}</b> published</span>{{end}}
  </span>
  <span class="spacer"></span>
  <span class="subtle kbd-hint">press ? for keyboard shortcuts</span>
  <form method="post" action="{{$c.StateURL}}" class="inline-form" id="accept-all-form">
    <input type="hidden" name="project" value="{{$c.Nav.Project}}">
    <input type="hidden" name="iid" value="{{$c.Nav.IID}}">
    <input type="hidden" name="record" value="{{$c.RecordName}}">
    <input type="hidden" name="action" value="accept-all">
    <button type="submit" class="button">{{template "icon" "check"}} Accept all pending</button>
  </form>
  <a class="button primary{{if not $c.Accepted}} disabled{{end}}" id="publish-button" href="{{$c.PublishURL}}">
    Publish <b id="count-publish">{{$c.Accepted}}</b> accepted
  </a>
</footer>
{{end}}
{{end}}
